# 佛学大师项目 - 环境变量配置模板

# ============ AI API配置 ============
# 通义千问 (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=

# AI提供商选择: dashscope 或 openai
AI_PROVIDER=dashscope

# ============ 数据库配置 ============
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=buddhism_master
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============ 向量数据库配置 ============
# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=buddhism_knowledge

# 向量数据库选择: milvus 或 qdrant
VECTOR_DB_PROVIDER=milvus

# ============ 应用配置 ============
DEBUG=true
HOST=0.0.0.0
PORT=8000
